# Frontend
VITE_API_URL=http://localhost:3001

# API
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ata_portal

# Better Auth (embutido na API)
BETTER_AUTH_SECRET=dev-secret-change-me-please-32chars-minimum
BETTER_AUTH_URL=http://localhost:3001

# Aplicação (URLs de referência)
APP_ENV=development
APP_WEB_URL=http://localhost:5173
APP_API_URL=http://localhost:3001

# Geocoding de rotas
NOMINATIM_BASE_URL=http://localhost:8080
